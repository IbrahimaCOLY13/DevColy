      <Option value="VERIFICATION DES DONNEES ET AJOUT DE OUI DANS CHAMP aFaireReco :&#xa;CASE&#xa;WHEN &quot;COORLAMZ&quot; &lt; 0 THEN 'Oui'&#xa;WHEN &quot;COORLAMF&quot; = 0 THEN 'Oui'&#xa;WHEN &quot;COORLAMF&quot; is NULL THEN 'Oui'&#xa;WHEN &quot;COORLAMF&quot; &lt; 0 THEN 'Oui'&#xa;WHEN &quot;COORLAMZ&quot; IS NULL AND &quot;COORLAMF&quot; IS NULL THEN 'Oui'&#xa;WHEN &quot;COORLAMZ&quot; =0 AND &quot;COORLAMF&quot; =0 THEN 'Oui'&#xa;WHEN &quot;COORLAMZ&quot; IS NULL AND &quot;COORLAMF&quot; =0 THEN 'Oui'&#xa;WHEN &quot;COORLAMZ&quot; =0 AND &quot;COORLAMF&quot; IS NULL THEN 'Oui'&#xa;WHEN &quot;PROFOND&quot; =0 AND &quot;COORLAMF&quot; =0 THEN 'Oui'&#xa;WHEN &quot;COORLAMZ&quot; &lt; (&quot;COORLAMF&quot;) THEN 'Oui'&#xa;WHEN &quot;PROFOND&quot; &lt; 0 THEN 'Oui'&#xa;WHEN &quot;EnDouble&quot;='Oui' THEN 'Oui'&#xa;WHEN &quot;E_VRMS&quot; = 0 Or &quot;E_HRMS&quot;=0 THEN 'Oui'&#xa;WHEN &quot;E_VRMS&quot; > 0.4 Or &quot;E_HRMS&quot;>0.4 THEN 'Oui'&#xa;WHEN &quot;E_VRMS&quot; &lt; 0 Or &quot;E_HRMS&quot;&lt;0 THEN 'Oui'&#xa;WHEN &quot;E_VRMS&quot; is NULL Or &quot;E_HRMS&quot; IS NULL THEN 'Oui'&#xa;ELSE 'Non'&#xa;END" name="component_description" type="QString"/>
