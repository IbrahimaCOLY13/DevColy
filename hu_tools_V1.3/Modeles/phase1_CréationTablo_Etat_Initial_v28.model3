            <Option type="QString" name="static_value" value="CASE &#xd;&#xa;WHEN &quot;cdHER1&quot;=1 THEN 'PYRENEES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=2 THEN 'ALPES INTERNES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=3 THEN 'MASSIF CENTRAL SUD'&#xd;&#xa;WHEN &quot;CdHER1&quot;=4 THEN 'VOSGES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=5 THEN 'JURA-PREALPES DU NORD'&#xd;&#xa;WHEN &quot;CdHER1&quot;=6 THEN 'MEDITERRANEEN'&#xd;&#xa;WHEN &quot;CdHER1&quot;=7 THEN 'PREALPES DU SUD'&#xd;&#xa;WHEN &quot;CdHER1&quot;=8 THEN 'CEVENNES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=9 THEN 'TABLES CALCAIRES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=10 THEN 'COTES CALCAIRES EST'&#xd;&#xa;WHEN &quot;CdHER1&quot;=11 THEN 'CAUSSES AQUITAINS'&#xd;&#xa;WHEN &quot;CdHER1&quot;=12 THEN 'ARMORICAIN'&#xd;&#xa;WHEN &quot;CdHER1&quot;=13 THEN 'LANDES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=14 THEN 'COTEAUX AQUITAINS'&#xd;&#xa;WHEN &quot;CdHER1&quot;=15 THEN 'PLAINE SAONE'&#xd;&#xa;WHEN &quot;CdHER1&quot;=16 THEN 'CORSE'&#xd;&#xa;WHEN &quot;CdHER1&quot;=17 THEN 'DEPRESSIONS SEDIMENTAIRES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=18 THEN 'ALSACE'&#xd;&#xa;WHEN &quot;CdHER1&quot;=19 THEN 'GRANDS CAUSSES'&#xd;&#xa;WHEN &quot;CdHER1&quot;=20 THEN 'DEPOTS ARGILEUX SABLEUX'&#xd;&#xa;WHEN &quot;CdHER1&quot;=21 THEN 'MASSIF CENTRAL NORD'&#xd;&#xa;WHEN &quot;CdHER1&quot;=22 THEN 'ARDENNES'&#xd;&#xa;END"/>
          </Option>
        </Option>
        <Option type="List" name="INPUT">
          <Option type="Map">
            <Option type="QString" name="child_id" value="native:extractbylocation_22"/>
            <Option type="QString" name="output_name" value="OUTPUT"/>
            <Option type="int" name="source" value="1"/>
          </Option>
        </Option>
      </Option>
    </Option>
