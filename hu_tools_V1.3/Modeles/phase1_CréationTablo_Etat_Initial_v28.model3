        <Option type="List" name="FORMULA">
          <Option type="Map">
            <Option type="int" name="source" value="2"/>
            <Option type="QString" name="static_value" value="CASE &#xd;&#xa;WHEN &quot;code_18&quot;= 111 THEN 'Tissu urbain continu'&#xd;&#xa;WHEN &quot;code_18&quot;= 112 THEN 'Tissu urbain discontinu'&#xd;&#xa;WHEN &quot;code_18&quot;= 121 THEN 'Zones industrielles ou commerciales et installations publiques'&#xd;&#xa;WHEN &quot;code_18&quot;= 122 THEN 'Réseaux routier et ferroviaire et espaces associés'&#xd;&#xa;WHEN &quot;code_18&quot;= 123 THEN 'Zones portuaires'&#xd;&#xa;WHEN &quot;code_18&quot;= 124 THEN 'Aéroports'&#xd;&#xa;WHEN &quot;code_18&quot;= 131 THEN 'Extraction de matériaux'&#xd;&#xa;WHEN &quot;code_18&quot;= 132 THEN 'Décharges'&#xd;&#xa;WHEN &quot;code_18&quot;= 133 THEN 'Chantiers'&#xd;&#xa;WHEN &quot;code_18&quot;= 141 THEN 'Espaces verts urbains'&#xd;&#xa;WHEN &quot;code_18&quot;= 142 THEN 'Equipements sportifs et de loisirs'&#xd;&#xa;WHEN &quot;code_18&quot;= 211 THEN 'Terres arables hors périmètres d\'irrigation'&#xd;&#xa;WHEN &quot;code_18&quot;= 212 THEN 'Périmètres irrigués en permanence'&#xd;&#xa;WHEN &quot;code_18&quot;= 213 THEN 'Rizières'&#xd;&#xa;WHEN &quot;code_18&quot;= 221 THEN 'Vignobles'&#xd;&#xa;WHEN &quot;code_18&quot;= 222 THEN 'Vergers et petits fruits'&#xd;&#xa;WHEN &quot;code_18&quot;= 223 THEN 'Oliveraies'&#xd;&#xa;WHEN &quot;code_18&quot;= 231 THEN 'Prairies et autres surfaces toujours en herbe à usage agricole'&#xd;&#xa;WHEN &quot;code_18&quot;= 241 THEN 'Cultures annuelles associées à des cultures permanentes'&#xd;&#xa;WHEN &quot;code_18&quot;= 242 THEN 'Systèmes culturaux et parcellaires complexes'&#xd;&#xa;WHEN &quot;code_18&quot;= 243 THEN 'Surfaces essentiellement agricoles, interrompues par des espaces naturels importants'&#xd;&#xa;WHEN &quot;code_18&quot;= 244 THEN 'Territoires agroforestiers'&#xd;&#xa;WHEN &quot;code_18&quot;= 311 THEN 'Forêts de feuillus'&#xd;&#xa;WHEN &quot;code_18&quot;= 312 THEN 'Forêts de conifères'&#xd;&#xa;WHEN &quot;code_18&quot;= 313 THEN 'Forêts mélangées'&#xd;&#xa;WHEN &quot;code_18&quot;= 321 THEN 'Pelouses et pâturages naturels'&#xd;&#xa;WHEN &quot;code_18&quot;= 322 THEN 'Landes et broussailles'&#xd;&#xa;WHEN &quot;code_18&quot;= 323 THEN 'Végétation sclérophylle'&#xd;&#xa;WHEN &quot;code_18&quot;= 324 THEN 'Forêt et végétation arbustive en mutation'&#xd;&#xa;WHEN &quot;code_18&quot;= 331 THEN 'Plages, dunes et sable'&#xd;&#xa;WHEN &quot;code_18&quot;= 332 THEN 'Roches nues'&#xd;&#xa;WHEN &quot;code_18&quot;= 333 THEN 'Végétation clairsemée'&#xd;&#xa;WHEN &quot;code_18&quot;= 334 THEN 'Zones incendiées'&#xd;&#xa;WHEN &quot;code_18&quot;= 335 THEN 'Glaciers et neiges éternelles'&#xd;&#xa;WHEN &quot;code_18&quot;= 411 THEN 'Marais intérieurs'&#xd;&#xa;WHEN &quot;code_18&quot;= 412 THEN 'Tourbières'&#xd;&#xa;WHEN &quot;code_18&quot;= 421 THEN 'Marais maritimes'&#xd;&#xa;WHEN &quot;code_18&quot;= 422 THEN 'Marais salants'&#xd;&#xa;WHEN &quot;code_18&quot;= 423 THEN 'Zones intertidales'&#xd;&#xa;WHEN &quot;code_18&quot;= 511 THEN 'Cours et voies d\'eau'&#xd;&#xa;WHEN &quot;code_18&quot;= 512 THEN 'Plans d\'eau'&#xd;&#xa;WHEN &quot;code_18&quot;= 521 THEN 'Lagunes littorales'&#xd;&#xa;WHEN &quot;code_18&quot;= 522 THEN 'Estuaires'&#xd;&#xa;WHEN &quot;code_18&quot;= 523 THEN 'Mers et océans'&#xd;&#xa;&#xd;&#xa;END"/>
          </Option>
        </Option>
        <Option type="List" name="INPUT">
          <Option type="Map">
            <Option type="QString" name="child_id" value="native:addfieldtoattributestable_6"/>
            <Option type="QString" name="output_name" value="OUTPUT"/>
